# Telegram
TELEGRAM_BOT_TOKEN=

# Yandex SpeechKit (ASR, регион Казахстан)
YANDEX_SPEECHKIT_API_KEY=
YANDEX_FOLDER_ID=
# Опционально. По умолчанию = STT host (stt.api.ml.yandexcloud.kz).
# НЕ ставьте operation.api.ml.yandexcloud.kz — в KZ этот хост не резолвится.
# YANDEX_STT_SERVICE_URL=https://stt.api.ml.yandexcloud.kz
# YANDEX_OPERATION_SERVICE_URL=https://stt.api.ml.yandexcloud.kz

# Anthropic Claude (LLM-структурирование отчётов)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5            # опционально

# Backend IE:AION
IE_AION_BACKEND_URL=https://<ваш-backend>.up.railway.app
# Тот же ключ, что задан как BOT_BACKEND_API_KEY в окружении backend IE:AION.
BOT_BACKEND_API_KEY=

# Путь к системному промпту LLM (по умолчанию voice-report-system-prompt.md)
# SYSTEM_PROMPT_PATH=voice-report-system-prompt.md
